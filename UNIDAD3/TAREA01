public class MetodoBurbuja {
    public static void main(String[] args) {
        // 1. Definimos un arreglo desordenado
        int[] numeros = {5, 2, 8, 1, 9};

        System.out.println("Arreglo original:");
        imprimirArreglo(numeros);

        // 2. Algoritmo de Ordenamiento Burbuja
        int n = numeros.length;
        for (int i = 0; i < n - 1; i++) {
            for (int j = 0; j < n - 1 - i; j++) {
                // Si el número actual es mayor que el siguiente, se intercambian
                if (numeros[j] > numeros[j + 1]) {
                    int temporal = numeros[j];
                    numeros[j] = numeros[j + 1];
                    numeros[j + 1] = temporal;
                }
            }
        }

        System.out.println("\nArreglo ordenado:");
        imprimirArreglo(numeros);
    }

    // Método auxiliar para mostrar el arreglo en consola
    public static void imprimirArreglo(int[] arreglo) {
        for (int num : arreglo) {
            System.out.print(num + " ");
        }
        System.out.println();
    }
}

